{
  "name": "ultraenv",
    "version": "1.0.4",
  "description": "The Ultimate Environment Variable Manager — Validate, Type, Encrypt, Sync, and Never Ship Broken Configs Again",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./middleware": {
      "import": "./dist/middleware/express.js",
      "require": "./dist/middleware/express.cjs",
      "types": "./dist/middleware/express.d.ts"
    },
    "./fastify": {
      "import": "./dist/middleware/fastify.js",
      "require": "./dist/middleware/fastify.cjs",
      "types": "./dist/middleware/fastify.d.ts"
    },
    "./schema": {
      "import": "./dist/schema/index.js",
      "require": "./dist/schema/index.cjs",
      "types": "./dist/schema/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ultraenv": "./bin/ultraenv.mjs"
  },
  "files": [
    "dist",
    "bin",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts src/schema/index.ts src/middleware/express.ts src/middleware/fastify.ts src/cli/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "cli": "node bin/ultraenv.mjs",
    "prepack": "echo skipping husky"
  },
  "keywords": [
    "env",
    "dotenv",
    "environment",
    "variables",
    "config",
    "configuration",
    "validation",
    "typescript",
    "types",
    "encryption",
    "vault",
    "secrets",
    "security",
    "schema",
    "secret-detection",
    "leak-detection",
    ".env",
    "cli",
    "devtools",
    "env-manager",
    "type-safe",
    "zero-dependency"
  ],
  "author": "Avinash Velu <avinashvelu03@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Avinashvelu03/ultraenv"
  },
  "bugs": {
    "url": "https://github.com/Avinashvelu03/ultraenv/issues"
  },
  "homepage": "https://github.com/Avinashvelu03/ultraenv#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Avinashvelu03"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "prettier": "^3.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
